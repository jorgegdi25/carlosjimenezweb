# URL publica definitiva, sin slash al final
SITE_URL=https://carlosalbertojimenez.com.co

# Empieza en sandbox. Cambia a production cuando las pruebas esten aprobadas.
WOMPI_ENVIRONMENT=sandbox
WOMPI_PUBLIC_KEY=pub_test_REEMPLAZAR
WOMPI_INTEGRITY_SECRET=test_integrity_REEMPLAZAR
WOMPI_EVENTS_SECRET=test_events_REEMPLAZAR

# Genera un valor aleatorio largo. No reutilices una llave de Wompi.
WOMPI_SESSION_SECRET=REEMPLAZAR_CON_UN_SECRETO_ALEATORIO

# Path exacto de cada archivo dentro de un Vercel Blob privado.
BLOB_NEUROMARKETING_PATH=libros/el-neuromarketing.pdf
# BLOB_DIALOGO_PATH=libros/dialogo-con-mi-cerebro.pdf
# BLOB_CEREBROS_PATH=libros/cerebros-digitales.pdf

# Automatizacion de acceso a cursos alojados en Google Drive.
# COURSE_APPS_SCRIPT_URL=https://script.google.com/macros/s/REEMPLAZAR/exec
# COURSE_AUTOMATION_SECRET=REEMPLAZAR_CON_EL_SECRETO_DE_APPS_SCRIPT

# Activar solo cuando Apps Script reconozca CAJ-CEREBROS-INTERACTIVO-
# y la carpeta definitiva del curso este configurada.
COURSE_CEREBROS_DIGITALES_ENABLED=false
